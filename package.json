{
  "name": "getfit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "GetFit — a secure, client-side fitness web app built on the open exercises-dataset (ExerciseDB v1).",
  "scripts": {
    "prepare-data": "node scripts/prepare-data.mjs",
    "dev": "vite",
    "build": "npm run prepare-data && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
